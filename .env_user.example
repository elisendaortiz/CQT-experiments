# ~/.env_user — user-level secrets file
#
# This file lives at your HOME directory (~/.env_user), NOT inside any repo.
# Set permissions to owner-read-only: chmod 600 ~/.env_user
#
# Copy this file to ~ and fill in real values:
#   cp .env_user.example ~/.env_user
#   chmod 600 ~/.env_user

# CQT experiment server
CQT_SERVER_URL=http://<server-ip>
CQT_API_TOKEN=<your-api-token>

# Qibo DB
CQT_QIBODB_HOST=http://<qibodb-host>
CQT_QIBODB_KEY=<your-qibodb-key>
